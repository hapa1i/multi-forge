# Claude Forge Environment Variables
# Copy this file to .env and fill in values
#
# IMPORTANT: This file is for SECRETS ONLY (API keys, auth credentials).
# Configuration (models, ports, tier_overrides) goes in YAML files:
#   - src/forge/config/defaults/          (defaults)
#   - src/forge/config/defaults/templates/ (template overlays)
#   - ~/.forge/config.yaml                       (user overrides)
#   - ~/.forge/proxies/<id>/proxy.yaml           (proxy overrides)

# =============================================================================
# API KEYS (required for the provider you use)
# =============================================================================

# Anthropic API Key (the key used by Claude Code)
# Get from: https://console.anthropic.com/
# ANTHROPIC_API_KEY=

# Gemini API Key (for local LiteLLM with personal key)
# Get from: https://aistudio.google.com/apikey
# GEMINI_API_KEY=

# LiteLLM remote credentials
# LITELLM_API_KEY=

# =============================================================================
# LiteLLM BASE URLS
# =============================================================================

# Remote/shared LiteLLM gateway URL
# LITELLM_BASE_URL=

# Local LiteLLM URL (default: derived from backend_dependency port)
# LITELLM_LOCAL_BASE_URL=http://localhost:4000

# =============================================================================
# OPTIONAL PATH OVERRIDES
# =============================================================================

# Custom Forge home directory (default: ~/.forge)
FORGE_HOME=~/.forge
